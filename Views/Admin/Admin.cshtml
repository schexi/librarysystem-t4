@{
ViewData["Title"] = "Admin";
Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1 class="page-title">⚙️ Admin</h1>

<div class="glass-card" style="max-width:900px">
    <div class="stats-grid" style="margin-bottom:24px">
        <div class="stat-box">
            <label>👥 Totalt användare</label>
            <div id="totalVal" class="stat-value">–</div>
        </div>
        <div class="stat-box">
            <label>🔑 Admins</label>
            <div id="adminsVal" class="stat-value">–</div>
        </div>
        <div class="stat-box">
            <label>👤 Vanliga användare</label>
            <div id="regularVal" class="stat-value">–</div>
        </div>
        <div class="stat-box">
            <label>📚 Aktiva lån</label>
            <div id="loansVal" class="stat-value">–</div>
        </div>
    </div>

    <div class="tabs" style="margin-bottom:20px">
        <button class="tab-btn active" onclick="showAdminTab('users')">👥 Användare</button>
        <button class="tab-btn" onclick="showAdminTab('create')">➕ Skapa användare</button>
        <button class="tab-btn" onclick="showAdminTab('overdue')">⚠️ Försenade lån</button>
    </div>

    <!-- ANVÄNDARLISTA -->
    <div id="usersTab">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px">
            <h2 style="font-size:1.1rem;font-weight:700">Alla användare</h2>
            <input class="search-input" id="userSearch" placeholder="🔍 Sök..." oninput="filterUsers()"/>
        </div>
        <table>
            <thead>
            <tr>
                <th>Id</th>
                <th>Namn</th>
                <th>Användarnamn</th>
                <th>E-post</th>
                <th>Roll</th>
                <th>Åtgärder</th>
            </tr>
            </thead>
            <tbody id="userBody"></tbody>
        </table>
    </div>

    <!-- SKAPA ANVÄNDARE -->
    <div id="createTab" style="display:none">
        <h2 style="font-size:1.1rem;font-weight:700;margin-bottom:16px">Skapa ny användare</h2>
        <div id="createAlert" class="alert alert-error"></div>
        <div id="createSuccess" class="alert alert-success"></div>
        <div class="form-row">
            <div class="form-group">
                <label>Förnamn</label>
                <input id="newFirstName" class="form-control" type="text"/>
            </div>
            <div class="form-group">
                <label>Efternamn</label>
                <input id="newLastName" class="form-control" type="text"/>
            </div>
        </div>
        <div class="form-group">
            <label>E-post</label>
            <input id="newEmail" class="form-control" type="email"/>
        </div>
        <div class="form-group">
            <label>Användarnamn</label>
            <input id="newUsername" class="form-control" type="text"/>
        </div>
        <div class="form-group">
            <label>Lösenord</label>
            <input id="newPassword" class="form-control" type="password"/>
        </div>
        <div class="form-group">
            <label>Roll</label>
            <select id="newRole" class="form-control">
                <option value="User">User</option>
                <option value="Admin">Admin</option>
            </select>
        </div>
        <button class="btn-primary" onclick="createUser()">Skapa användare</button>
    </div>

    <!-- FÖRSENADE LÅN -->
    <div id="overdueTab" style="display:none">
        <h2 style="font-size:1.1rem;font-weight:700;margin-bottom:16px">⚠️ Försenade lån</h2>
        <div id="overdueList"><p style="opacity:.7">Laddar...</p></div>
    </div>
</div>

@section Scripts {
<script>
    let allUsers = [];

    (async () => {
        const res = await apiFetch('/api/admin/stats');
        if (!res.ok) return;
        const d = await res.json();
        document.getElementById('totalVal').textContent   = d.total;
        document.getElementById('adminsVal').textContent  = d.admins;
        document.getElementById('regularVal').textContent = d.regular;
        document.getElementById('loansVal').textContent   = d.loans;
    })();

    (async () => {
        const res = await apiFetch('/api/admin/user-list');
        if (!res.ok) return;
        allUsers = await res.json();
        renderUsers(allUsers);
    })();

    function renderUsers(users) {
        document.getElementById('userBody').innerHTML = users.map(u => `
        <tr>
            <td>${u.id}</td>
            <td>${u.firstName} ${u.lastName}</td>
            <td>${u.username}</td>
            <td>${u.email}</td>
            <td>
                <select onchange="changeRole(${u.id}, this.value)"
                    style="background:rgba(255,255,255,.2);border:none;color:#fff;border-radius:6px;padding:3px 8px;font-family:Outfit,sans-serif">
                    <option value="User"  ${u.role==='User'  ? 'selected':''}>User</option>
                    <option value="Admin" ${u.role==='Admin' ? 'selected':''}>Admin</option>
                </select>
            </td>
            <td style="display:flex;gap:6px">
                <button class="btn-danger" onclick="deleteUser(${u.id})">🗑 Radera</button>
                <button class="btn-secondary" onclick="resetPassword(${u.id})">🔑 Lösenord</button>
            </td>
        </tr>
    `).join('');
    }

    function filterUsers() {
        const q = document.getElementById('userSearch').value.toLowerCase();
        renderUsers(allUsers.filter(u =>
            (u.firstName + ' ' + u.lastName).toLowerCase().includes(q) ||
            u.username.toLowerCase().includes(q) ||
            u.email.toLowerCase().includes(q)
        ));
    }

    async function changeRole(id, newRole) {
        const res = await apiFetch(`/api/admin/user/${id}/change-role?newRole=${newRole}`, { method: 'PATCH' });
        if (res.ok) showToast('Roll uppdaterad!');
    }

    async function deleteUser(id) {
        if (!confirm('Säker på att du vill radera användaren?')) return;
        const res = await apiFetch(`/api/admin/user/${id}`, { method: 'DELETE' });
        if (res.ok) {
            allUsers = allUsers.filter(u => u.id !== id);
            renderUsers(allUsers);
            showToast('Användaren raderad!');
            refreshStats();
        }
}

    async function resetPassword(id) {
        const newPass = prompt('Ange nytt lösenord:');
        if (!newPass) return;
        const user = allUsers.find(u => u.id === id);
        if (!user) return;
        const res = await apiFetch(`/api/admin/user/${id}/force-update`, {
            method: 'PUT',
            body: JSON.stringify({
                firstName: user.firstName,
                lastName:  user.lastName,
                email:     user.email,
                username:  user.username,
                role:      user.role,
                passwordHash: newPass
            })
        });
        if (res.ok) showToast('Lösenord uppdaterat!');
    }

    async function createUser() {
        const alertBox   = document.getElementById('createAlert');
        const successBox = document.getElementById('createSuccess');
        alertBox.style.display   = 'none';
        successBox.style.display = 'none';

        const role     = document.getElementById('newRole').value;
        const adminCode = role === 'Admin' ? 'HvAdmin2026!' : null;

        const res = await apiFetch('/api/auth/register', {
            method: 'POST',
            body: JSON.stringify({
                firstName:    document.getElementById('newFirstName').value,
                lastName:     document.getElementById('newLastName').value,
                email:        document.getElementById('newEmail').value,
                username:     document.getElementById('newUsername').value,
                passwordHash: document.getElementById('newPassword').value,
                adminCode:    adminCode
            })
        });

        if (res.ok) {
            successBox.textContent   = 'Användaren skapades!';
            successBox.style.display = 'block';
            document.getElementById('newFirstName').value = '';
            document.getElementById('newLastName').value  = '';
            document.getElementById('newEmail').value     = '';
            document.getElementById('newUsername').value  = '';
            document.getElementById('newPassword').value  = '';
            const updatedRes = await apiFetch('/api/admin/user-list');
            if (updatedRes.ok) { allUsers = await updatedRes.json(); }
            refreshStats();
        } else {
            alertBox.textContent   = await res.text() || 'Något gick fel.';
            alertBox.style.display = 'block';
        }
}

    async function loadOverdue() {
        const res = await apiFetch('/api/loans/overdue');
        if (!res.ok) return;
        const loans = await res.json();
        document.getElementById('overdueList').innerHTML = loans.length === 0
            ? '<p style="opacity:.7;text-align:center;padding:20px">Inga försenade lån! 🎉</p>'
            : loans.map(l => `
            <div class="loan-item">
                <div>
                    <div class="loan-title">${l.bookTitle}</div>
                    <div class="loan-author">${l.bookAuthor}</div>
                    <div style="font-size:.8rem;opacity:.6;margin-top:4px">
                        Användare: ${l.user?.username || '–'} •
                        Förföll: <span style="color:#ff6b6b">${new Date(l.dueDate).toLocaleDateString('sv-SE')}</span>
                    </div>
                </div>
                <span class="loan-badge" style="background:rgba(220,50,50,.3);color:#ff9999">⚠️ Försenad</span>
            </div>
        `).join('');
    }

    async function refreshStats() {
        const res = await apiFetch('/api/admin/stats');
        if (!res.ok) return;
        const d = await res.json();
        document.getElementById('totalVal').textContent   = d.total;
        document.getElementById('adminsVal').textContent  = d.admins;
        document.getElementById('regularVal').textContent = d.regular;
        document.getElementById('loansVal').textContent   = d.loans;
    }

    function showAdminTab(tab) {
        document.getElementById('usersTab').style.display   = tab === 'users'   ? 'block' : 'none';
        document.getElementById('createTab').style.display  = tab === 'create'  ? 'block' : 'none';
        document.getElementById('overdueTab').style.display = tab === 'overdue' ? 'block' : 'none';

        document.querySelectorAll('.tab-btn').forEach((btn, i) => {
            btn.classList.toggle('active', ['users','create','overdue'][i] === tab);
        });

        if (tab === 'overdue') loadOverdue();
    }

    function showToast(msg) {
        const toast = document.createElement('div');
        toast.textContent = msg;
        toast.style.cssText = `
        position:fixed; bottom:24px; right:24px;
        background:rgba(50,200,100,.9); color:#fff;
        padding:12px 24px; border-radius:12px;
        font-family:Outfit,sans-serif; font-size:.95rem;
        font-weight:600; z-index:9999;
        animation: fadeUp 0.3s ease;
        box-shadow: 0 4px 16px rgba(0,0,0,0.2);
    `;
        document.body.appendChild(toast);
        setTimeout(() => toast.remove(), 3000);
    }
</script>
}
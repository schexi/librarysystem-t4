@{
    ViewData["Title"] = "Användarlista";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1 class="page-title">👥 Alla användare</h1>

<div class="table-wrapper" style="max-width:1000px">
    <div class="table-header">
        <div style="display:flex;gap:10px;align-items:center">
            <h2>Användare</h2>
            <span id="userCount" style="background:rgba(255,255,255,.2);padding:3px 10px;border-radius:20px;font-size:.85rem">–</span>
        </div>
        <div style="display:flex;gap:10px">
            <input class="search-input" id="search" placeholder="🔍 Sök..." oninput="filterTable()"/>
            <select id="roleFilter" class="search-input" style="width:120px" onchange="filterTable()">
                <option value="all">Alla roller</option>
                <option value="User">User</option>
                <option value="Admin">Admin</option>
            </select>
        </div>
    </div>

    <table>
        <thead>
        <tr>
            <th onclick="sortBy('id')" style="cursor:pointer">Id ↕</th>
            <th onclick="sortBy('name')" style="cursor:pointer">Namn ↕</th>
            <th>Användarnamn</th>
            <th>E-post</th>
            <th onclick="sortBy('role')" style="cursor:pointer">Roll ↕</th>
            <th>Skapad</th>
            <th>Åtgärder</th>
        </tr>
        </thead>
        <tbody id="userBody"></tbody>
    </table>

    <div id="noResults" style="display:none;text-align:center;padding:30px;opacity:.7">
        Inga användare hittades 🔍
    </div>
</div>

@section Scripts {
<script>
    let allUsers = [];
    let sortCol  = 'id';
    let sortAsc  = true;

    (async () => {
        const res = await apiFetch('/api/admin/user-list');
        if (!res.ok) { window.location.href = '/Authorization/Login'; return; }
        allUsers = await res.json();
        renderTable(allUsers);
    })();

    function renderTable(users) {
        document.getElementById('userCount').textContent = users.length + ' st';
        const noRes = document.getElementById('noResults');
        const body  = document.getElementById('userBody');

        if (users.length === 0) {
            body.innerHTML = '';
            noRes.style.display = 'block';
            return;
        }

        noRes.style.display = 'none';
        body.innerHTML = users.map((u, i) => `
        <tr style="animation:fadeUp 0.3s ease ${i * 0.03}s both">
            <td>${u.id}</td>
            <td><div style="font-weight:600">${u.firstName} ${u.lastName}</div></td>
            <td>${u.username}</td>
            <td>${u.email}</td>
            <td>
                <select onchange="changeRole(${u.id}, this.value)"
                    style="background:rgba(255,255,255,.2);border:none;color:#fff;border-radius:6px;padding:3px 8px;font-family:inherit">
                    <option value="User"  ${u.role==='User'  ? 'selected':''}>👤 User</option>
                    <option value="Admin" ${u.role==='Admin' ? 'selected':''}>🔑 Admin</option>
                </select>
            </td>
            <td style="font-size:.8rem;opacity:.7">${formatDate(u.createdAt)}</td>
            <td>
                <div style="display:flex;gap:6px;flex-wrap:wrap">
                    <button class="btn-danger" onclick="deleteUser(${u.id})">🗑</button>
                    <button class="btn-secondary" onclick="resetPw(${u.id}, '${u.firstName}', '${u.lastName}', '${u.email}', '${u.username}', '${u.role}')">🔑</button>
                </div>
            </td>
        </tr>
    `).join('');
    }

    function filterTable() {
        const q    = document.getElementById('search').value.toLowerCase();
        const role = document.getElementById('roleFilter').value;
        let filtered = allUsers.filter(u => {
            const matchQ    = (u.firstName + ' ' + u.lastName).toLowerCase().includes(q) ||
                u.username.toLowerCase().includes(q) ||
                u.email.toLowerCase().includes(q);
            const matchRole = role === 'all' || u.role === role;
            return matchQ && matchRole;
        });
        filtered = sortUsers(filtered);
        renderTable(filtered);
    }

    function sortBy(col) {
        if (sortCol === col) sortAsc = !sortAsc;
        else { sortCol = col; sortAsc = true; }
        filterTable();
    }

    function sortUsers(users) {
        return [...users].sort((a, b) => {
            let va, vb;
            if (sortCol === 'id')   { va = a.id;        vb = b.id; }
            if (sortCol === 'name') { va = a.firstName;  vb = b.firstName; }
            if (sortCol === 'role') { va = a.role;       vb = b.role; }
            if (va < vb) return sortAsc ? -1 : 1;
            if (va > vb) return sortAsc ?  1 : -1;
            return 0;
        });
    }

    async function changeRole(id, newRole) {
        const res = await apiFetch(`/api/admin/user/${id}/change-role?newRole=${newRole}`, { method: 'PATCH' });
        if (res.ok) showToast('✅ Roll uppdaterad!');
    }

    async function deleteUser(id) {
        if (!confirm('Säker på att du vill radera användaren?')) return;
        const res = await apiFetch(`/api/admin/user/${id}`, { method: 'DELETE' });
        if (res.ok) {
            allUsers = allUsers.filter(u => u.id !== id);
            filterTable();
            showToast('🗑 Användaren raderad!');
        }
    }

    async function resetPw(id, fn, ln, email, username, role) {
        const newPass = prompt('Ange nytt lösenord för ' + fn + ':');
        if (!newPass) return;
        const res = await apiFetch(`/api/admin/user/${id}/force-update`, {
            method: 'PUT',
            body: JSON.stringify({ firstName: fn, lastName: ln, email, username, role, passwordHash: newPass })
        });
        if (res.ok) showToast('🔑 Lösenord uppdaterat!');
    }

    function formatDate(d) {
        if (!d) return '–';
        return new Date(d).toLocaleDateString('sv-SE');
    }

    function showToast(msg) {
        const toast = document.createElement('div');
        toast.textContent = msg;
        toast.style.cssText = `
            position:fixed; bottom:24px; right:24px;
            background:rgba(50,200,100,.9); color:#fff;
            padding:12px 24px; border-radius:12px;
            font-family:inherit; font-size:.95rem;
            font-weight:600; z-index:9999;
            box-shadow:0 4px 16px rgba(0,0,0,0.2);
        `;
        document.body.appendChild(toast);
        setTimeout(() => toast.remove(), 3000);
    }
</script>
}
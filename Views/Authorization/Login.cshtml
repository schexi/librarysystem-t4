@{
    ViewData["Title"] = "Logga in";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1 class="page-title">Logga in</h1>

<div class="glass-card" style="max-width:480px">
    <div id="alertBox" class="alert alert-error"></div>
    <div class="form-group">
        <label>Användarnamn</label>
        <input id="username" class="form-control" type="text" placeholder="ditt användarnamn"/>
    </div>
    <div class="form-group">
        <label>Lösenord</label>
        <input id="password" class="form-control" type="password" placeholder="••••••••"/>
    </div>
    <button class="btn-primary" onclick="login()">Sign in</button>
    <p style="text-align:center;margin-top:14px;font-size:.9rem;opacity:.8">
        Inget konto? <a href="/Authorization/Register" style="color:#fff;font-weight:600">Registrera</a>
    </p>
</div>

@section Scripts {
    <script>
async function login() {
    const username = document.getElementById('username').value;
    const password = document.getElementById('password').value;
    const alert    = document.getElementById('alertBox');

    const res = await apiFetch('/api/auth/login', {
        method: 'POST',
        body: JSON.stringify({ username, password })
    });

    if (res.ok) {
        const data = await res.json();
        window.location.href = data.role === 'Admin' ? '/Admin' : '/User/Profile';
    } else {
        const msg = await res.text();
        alert.textContent = msg || 'Fel användarnamn eller lösenord.';
        alert.style.display = 'block';
    }
        }

document.addEventListener('keydown', e => { if (e.key === 'Enter') login(); });
</script>
}
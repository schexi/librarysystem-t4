@{
    ViewData["Title"] = "Lånhistorik";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1 class="page-title">Lånhistorik</h1>

<div class="glass-card" style="max-width:800px">
    <div class="tabs">
        <button class="tab-btn active" onclick="showTab('active')">Aktiva lån</button>
        <button class="tab-btn" onclick="showTab('returned')">Returnerade</button>
        <button class="tab-btn" onclick="showTab('bookings')">Bokningar</button>
    </div>

    <div id="activeTab">
        <div id="activeLoans"><p style="opacity:.7">Laddar...</p></div>
    </div>

    <div id="returnedTab" style="display:none">
        <div id="returnedLoans"><p style="opacity:.7">Laddar...</p></div>
    </div>

    <div id="bookingsTab" style="display:none">
        <div id="bookingsList"><p style="opacity:.7">Laddar...</p></div>
    </div>
</div>

@section Scripts {
<script>
let loans    = [];
let bookings = [];

(async () => {
    const res = await apiFetch('/api/user/me');
    if (!res.ok) { window.location.href = '/Authorization/Login'; return; }
    const { user } = await res.json();

    const [loansRes, bookingsRes] = await Promise.all([
        apiFetch(`/api/loans/user/${user.id}`),
        apiFetch(`/api/bookings/user/${user.id}`)
    ]);

    if (loansRes.ok)    loans    = await loansRes.json();
    if (bookingsRes.ok) bookings = await bookingsRes.json();

    renderActive();
    renderReturned();
    renderBookings();
})();

function renderActive() {
    const active = loans.filter(l => !l.isReturned);
    document.getElementById('activeLoans').innerHTML = active.length === 0
        ? '<p style="opacity:.7;text-align:center;padding:20px">Inga aktiva lån</p>'
        : active.map(l => loanCard(l)).join('');
}

function renderReturned() {
    const returned = loans.filter(l => l.isReturned);
    document.getElementById('returnedLoans').innerHTML = returned.length === 0
        ? '<p style="opacity:.7;text-align:center;padding:20px">Inga returnerade lån</p>'
        : returned.map(l => loanCard(l)).join('');
}

function renderBookings() {
    document.getElementById('bookingsList').innerHTML = bookings.length === 0
        ? '<p style="opacity:.7;text-align:center;padding:20px">Inga bokningar</p>'
        : bookings.map(b => `
            <div class="loan-item">
                <div>
                    <div class="loan-title">${b.bookTitle}</div>
                    <div class="loan-author">${b.bookAuthor}</div>
                    <div style="font-size:.8rem;opacity:.6;margin-top:4px">
                        Bokad: ${formatDate(b.bookingDate)}
                    </div>
                </div>
                <span class="loan-badge active">${b.status}</span>
            </div>
        `).join('');
}

function loanCard(l) {
    const due     = new Date(l.dueDate);
    const isLate  = !l.isReturned && due < new Date();
    return `
        <div class="loan-item">
            <div>
                <div class="loan-title">${l.bookTitle}</div>
                <div class="loan-author">${l.bookAuthor}</div>
                <div style="font-size:.8rem;opacity:.6;margin-top:4px">
                    Lånat: ${formatDate(l.borrowedDate)} •
                    Förfaller: <span style="color:${isLate ? '#ff6b6b' : 'inherit'}">${formatDate(l.dueDate)}</span>
                    ${l.isReturned ? '• Returnerat: ' + formatDate(l.returnedDate) : ''}
                </div>
            </div>
            <span class="loan-badge ${l.isReturned ? 'returned' : 'active'}">
                ${isLate ? '⚠️ Försenad' : l.isReturned ? 'Returnerad' : 'Aktiv'}
            </span>
        </div>
    `;
}

function formatDate(d) {
    if (!d) return '–';
    return new Date(d).toLocaleDateString('sv-SE');
}

function showTab(tab) {
    document.getElementById('activeTab').style.display   = tab === 'active'   ? 'block' : 'none';
    document.getElementById('returnedTab').style.display = tab === 'returned' ? 'block' : 'none';
    document.getElementById('bookingsTab').style.display = tab === 'bookings' ? 'block' : 'none';

    document.querySelectorAll('.tab-btn').forEach((btn, i) => {
        btn.classList.toggle('active', ['active','returned','bookings'][i] === tab);
    });
}
</script>
}
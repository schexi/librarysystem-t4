@{
    ViewData["Title"] = "Mina lån";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1 class="page-title">📖 Mina lån</h1>

<div class="glass-card" style="max-width:800px">
    <div class="tabs">
        <button class="tab-btn active" onclick="showTab('active')">Aktiva lån</button>
        <button class="tab-btn" onclick="showTab('returned')">Returnerade</button>
    </div>
    <div id="activeTab">
        <div id="activeLoans"><p style="opacity:.7;padding:20px">Laddar...</p></div>
    </div>
    <div id="returnedTab" style="display:none">
        <div id="returnedLoans"><p style="opacity:.7;padding:20px">Laddar...</p></div>
    </div>
</div>

@section Scripts {
<script>
let allLoans = [];

(async () => {
    const token    = localStorage.getItem('jwt_token');
    const userInfo = JSON.parse(localStorage.getItem('user_info') || 'null');

    if (!token || !userInfo) {
        window.location.href = '/Authorization/Login';
        return;
    }

    const res = await apiFetch(`/api/loans/user/${userInfo.id}`);

    if (!res.ok) {
        document.getElementById('activeLoans').innerHTML =
            '<p style="opacity:.7;padding:20px">Inga lån hittades.</p>';
        return;
    }

    allLoans = await res.json();
    renderActive();
    renderReturned();
})();

function renderActive() {
    const active = allLoans.filter(l => !l.isReturned);
    document.getElementById('activeLoans').innerHTML = active.length === 0
        ? '<p style="opacity:.7;text-align:center;padding:20px">Inga aktiva lån 📭</p>'
        : active.map(loanCard).join('');
}

function renderReturned() {
    const returned = allLoans.filter(l => l.isReturned);
    document.getElementById('returnedLoans').innerHTML = returned.length === 0
        ? '<p style="opacity:.7;text-align:center;padding:20px">Inga returnerade lån</p>'
        : returned.map(loanCard).join('');
}

function loanCard(l) {
    const due    = new Date(l.dueDate);
    const isLate = !l.isReturned && due < new Date();
    return `
        <div class="loan-item">
            <div style="flex:1">
                <div class="loan-title">${l.bookTitle}</div>
                <div class="loan-author">${l.bookAuthor || ''}</div>
                <div style="font-size:.8rem;opacity:.6;margin-top:4px">
                    Lånad: ${fmt(l.borrowedDate)} •
                    Förfaller: <span style="color:${isLate ? '#ff6b6b' : '#6ee7b7'}">${fmt(l.dueDate)}</span>
                    ${l.isReturned ? ' • Returnerad: ' + fmt(l.returnedDate) : ''}
                </div>
            </div>
            <div style="display:flex;flex-direction:column;align-items:flex-end;gap:8px">
                <span class="loan-badge ${l.isReturned ? 'returned' : 'active'}">
                    ${isLate ? '⚠️ Försenad' : l.isReturned ? '✅ Returnerad' : '📖 Aktiv'}
                </span>
                ${!l.isReturned ? `
                    <button onclick="returnLoan(${l.id})"
                        style="background:#06d6a0;border:none;color:#04342c;padding:6px 14px;border-radius:8px;font-weight:700;cursor:pointer;font-size:.85rem">
                        Återlämna
                    </button>` : ''}
            </div>
        </div>`;
}

async function returnLoan(id) {
    if (!confirm('Återlämna detta lån?')) return;
    const res = await apiFetch(`/api/loans/${id}/return`, { method: 'POST' });
    if (res.ok) {
        const loan = allLoans.find(l => l.id === id);
        if (loan) { loan.isReturned = true; loan.returnedDate = new Date().toISOString(); }
        renderActive();
        renderReturned();
        showToast('✅ Lån återlämnat!');
    } else {
        showToast('❌ Något gick fel.');
    }
}

function fmt(d) { return d ? new Date(d).toLocaleDateString('sv-SE') : '–'; }

function showTab(tab) {
    document.getElementById('activeTab').style.display   = tab === 'active'   ? 'block' : 'none';
    document.getElementById('returnedTab').style.display = tab === 'returned' ? 'block' : 'none';
    document.querySelectorAll('.tab-btn').forEach((b, i) =>
        b.classList.toggle('active', ['active','returned'][i] === tab));
}

function showToast(msg) {
    const t = document.createElement('div');
    t.textContent = msg;
    t.style.cssText = 'position:fixed;bottom:24px;right:24px;background:rgba(50,200,100,.9);color:#fff;padding:12px 24px;border-radius:12px;font-weight:600;z-index:9999;';
    document.body.appendChild(t);
    setTimeout(() => t.remove(), 3000);
}
</script>
}
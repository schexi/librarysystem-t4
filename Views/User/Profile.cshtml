@{
    ViewData["Title"] = "Profil";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1 class="page-title">Profil</h1>

<div class="glass-card">
    <div class="stats-grid">
        <div class="stat-box">
            <label>Användarnamn</label>
            <div id="usernameVal" class="stat-value" style="font-size:1.3rem">–</div>
        </div>
        <div class="stat-box">
            <label>E-post</label>
            <div id="emailVal" class="stat-value" style="font-size:1.1rem">–</div>
        </div>
        <div class="stat-box">
            <label>Aktiva lån</label>
            <div id="loansVal" class="stat-value">–</div>
        </div>
        <div class="stat-box">
            <label>Roll</label>
            <div id="roleVal" class="stat-value" style="font-size:1.3rem">–</div>
        </div>
    </div>
    <div style="margin-top:20px;text-align:center">
        <a href="/User/Update" class="btn-primary" style="display:inline-block;width:auto;padding:10px 32px">Uppdatera profil</a>
    </div>
</div>

@section Scripts {
    <script>
(async () => {
    const res = await apiFetch('/api/user/me');
    if (!res.ok) { window.location.href = '/Authorization/Login'; return; }
    const { user, activeLoans } = await res.json();
    document.getElementById('usernameVal').textContent = user.username;
    document.getElementById('emailVal').textContent    = user.email;
    document.getElementById('loansVal').textContent    = activeLoans;
    document.getElementById('roleVal').textContent     = user.role;
})();
</script>
}
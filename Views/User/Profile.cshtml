@{
    Layout = "~/Views/Shared/_Layout.cshtml"; // Kopplar layouten
    ViewData["Title"] = "Min profil";
}

<h2>Min profil</h2>

<div id="profile">Laddar profil...</div>

@section Scripts {
<script>
    async function loadProfile() {
        try {
            const res = await fetch('/api/user/me', { credentials: 'include' });
            if (!res.ok) {
                document.getElementById('profile').innerHTML = 'Kunde inte ladda profilen.';
                return;
            }
            const data = await res.json();

            const user = data.user;
            const activeLoans = data.activeLoans;

            document.getElementById('profile').innerHTML = `
            <p><strong>Användarnamn:</strong> ${user.username}</p>
            <p><strong>Förnamn:</strong> ${user.firstName}</p>
            <p><strong>Efternamn:</strong> ${user.lastName}</p>
            <p><strong>Email:</strong> ${user.email}</p>
            <p><strong>Aktiva lån:</strong> ${activeLoans}</p>
        `;
        } catch (error) {
            console.error(error);
            document.getElementById('profile').innerHTML = 'Fel vid laddning av profilen.';
        }
}

    // Kör funktionen efter att den definierats
    loadProfile();
</script>
}
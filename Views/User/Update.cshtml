@{
    ViewData["Title"] = "Uppdatera profil";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1 class="page-title">✏️ Uppdatera profil</h1>

<div class="glass-card" style="max-width:500px">
    <div id="alertBox" class="alert alert-error"></div>
    <div id="successBox" class="alert alert-success"></div>
    <div class="form-row">
        <div class="form-group">
            <label>Förnamn</label>
            <input id="firstName" class="form-control" type="text"/>
        </div>
        <div class="form-group">
            <label>Efternamn</label>
            <input id="lastName" class="form-control" type="text"/>
        </div>
    </div>
    <div class="form-group">
        <label>E-post</label>
        <input id="email" class="form-control" type="email"/>
    </div>
    <div class="form-group">
        <label>Nytt lösenord <span style="opacity:.6">(lämna tomt för oförändrat)</span></label>
        <input id="password" class="form-control" type="password"/>
    </div>
    <div style="display:flex;gap:12px;margin-top:10px">
        <button onclick="updateProfile()"
                style="background:#06d6a0;border:none;color:#04342c;padding:10px 24px;border-radius:10px;font-weight:700;cursor:pointer;font-size:1rem">
            💾 Spara
        </button>
        <a href="/User/Profile"
           style="background:rgba(255,255,255,0.15);border:1px solid rgba(255,255,255,0.3);color:white;padding:10px 24px;border-radius:10px;font-weight:700;text-decoration:none">
            ← Tillbaka
        </a>
    </div>
</div>

@section Scripts {
<script>
(async () => {
    const token = localStorage.getItem('jwt_token');
    if (!token) { window.location.href = '/Authorization/Login'; return; }

    const res = await apiFetch('/api/user/me');
    if (!res.ok) { window.location.href = '/Authorization/Login'; return; }

    const { user } = await res.json();
    document.getElementById('firstName').value = user.firstName;
    document.getElementById('lastName').value  = user.lastName;
    document.getElementById('email').value     = user.email;
})();

async function updateProfile() {
    const alertBox   = document.getElementById('alertBox');
    const successBox = document.getElementById('successBox');
    alertBox.style.display   = 'none';
    successBox.style.display = 'none';

    const res = await apiFetch('/api/user/update', {
        method: 'PUT',
        body: JSON.stringify({
            firstName:    document.getElementById('firstName').value,
            lastName:     document.getElementById('lastName').value,
            email:        document.getElementById('email').value,
            passwordHash: document.getElementById('password').value || null
        })
    });

    if (res.ok) {
        successBox.textContent   = '✅ Profilen uppdaterades!';
        successBox.style.display = 'block';
        setTimeout(() => window.location.href = '/User/Profile', 1500);
    } else {
        alertBox.textContent   = '❌ Något gick fel.';
        alertBox.style.display = 'block';
    }
}
</script>
}
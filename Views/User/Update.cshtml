@{
    Layout = "~/Views/Shared/_Layout.cshtml"; // Kopplar layouten
    ViewData["Title"] = "Min profil";
}

<h2>Uppdatera Profil</h2>

<form id="updateForm">
    <label>Förnamn:</label><br>
    <input type="text" id="firstName" /><br>

    <label>Efternamn:</label><br>
    <input type="text" id="lastName" /><br>

    <label>Email:</label><br>
    <input type="email" id="email" /><br>

    <label>Lösenord (valfritt):</label><br>
    <input type="password" id="password" /><br>

    <button type="submit">Uppdatera</button>
</form>

<div id="updateMessage"></div>

@section Scripts {
<script>
async function loadUserForUpdate() {
    try {
        const res = await fetch('/api/user/me', { credentials: 'include' });
        if (!res.ok) return;

        const data = await res.json();
        const user = data.user;

        document.getElementById('firstName').value = user.firstName;
        document.getElementById('lastName').value  = user.lastName;
        document.getElementById('email').value     = user.email;
    } catch (error) {
        console.error(error);
    }
}

document.getElementById('updateForm').addEventListener('submit', async e => {
    e.preventDefault();

    const dto = {
        firstName: document.getElementById('firstName').value,
        lastName:  document.getElementById('lastName').value,
        email:     document.getElementById('email').value,
        passwordHash: document.getElementById('password').value
    };

    try {
        const res = await fetch('/api/user/update', {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'include',
            body: JSON.stringify(dto)
        });

        if (!res.ok) {
            document.getElementById('updateMessage').innerText = 'Fel vid uppdatering.';
            return;
        }

        const updatedUser = await res.json();
        document.getElementById('updateMessage').innerText = 'Profil uppdaterad!';
    } catch (error) {
        console.error(error);
        document.getElementById('updateMessage').innerText = 'Fel vid uppdatering.';
    }
});

// Ladda användardata när sidan öppnas
loadUserForUpdate();
</script>
}
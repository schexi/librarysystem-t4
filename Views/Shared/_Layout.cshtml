<!DOCTYPE html>
<html lang="sv">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] - HV Bibliotek</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            background: linear-gradient(135deg, #0d3b6e 0%, #1b9aaa 50%, #06d6a0 100%);
            min-height: 100vh;
            font-family: 'Segoe UI', sans-serif;
            display: flex;
            flex-direction: column;
        }
        nav {
            background: rgba(255,255,255,0.15) !important;
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255,255,255,0.25) !important;
            border-radius: 16px;
            margin: 16px;
            padding: 10px 24px !important;
        }
        .navbar-brand {
            color: white !important;
            font-weight: 700;
            font-size: 1.3rem;
        }
        .nav-link {
            color: white !important;
            font-weight: 600;
            padding: 10px 20px !important;
            border-radius: 8px;
            font-size: 1rem !important;
            border: 1px solid rgba(255,255,255,0.3);
            transition: background 0.2s;
        }
        .nav-link:hover {
            background: rgba(255,255,255,0.2);
            color: white !important;
        }
        .btn-login {
            background: rgba(255,255,255,0.15);
            border: 1px solid rgba(255,255,255,0.3);
            color: white !important;
            border-radius: 20px;
            padding: 0.3rem 1.2rem;
            font-size: 0.9rem;
            cursor: pointer;
            text-decoration: none;
            transition: background 0.2s;
        }
        .btn-login:hover {
            background: rgba(255,255,255,0.25);
            color: white !important;
        }
        .btn-logout {
            background: rgba(244,63,94,0.2);
            border: 1px solid rgba(244,63,94,0.4);
            color: #fda4af !important;
            border-radius: 20px;
            padding: 0.3rem 1.2rem;
            font-size: 0.9rem;
            cursor: pointer;
            text-decoration: none;
            transition: background 0.2s;
        }
        .btn-logout:hover {
            background: rgba(244,63,94,0.35);
        }
        .alert-box {
            margin: 0 16px;
            padding: 12px 20px;
            border-radius: 10px;
            font-size: 0.9rem;
            display: none;
        }
        .alert-success {
            background: rgba(16,185,129,0.2);
            border: 1px solid rgba(16,185,129,0.4);
            color: #6ee7b7;
        }
        .alert-error {
            background: rgba(244,63,94,0.2);
            border: 1px solid rgba(244,63,94,0.4);
            color: #fda4af;
        }
        main {
            flex: 1;
            padding: 0 16px;
        }
        footer {
            background: rgba(0,0,0,0.2);
            color: rgba(255,255,255,0.7);
            text-align: center;
            padding: 16px;
            font-size: 0.85rem;
            border-top: 1px solid rgba(255,255,255,0.1);
        }
    </style>
</head>
<body>
<header>
    <nav class="navbar navbar-expand-sm">
        <div class="container-fluid">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">HV Bibliotek</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="navbar-collapse collapse d-sm-inline-flex justify-content-center flex-grow-1">
                <ul class="navbar-nav gap-2">
                    <!-- Alltid synliga -->
                    <li class="nav-item">
                        <a class="nav-link" href="#" onclick="goToT4('/Items')">Böcker</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Categories" asp-action="Index">Kategorier</a>
                    </li>
                    <!-- Endast för inloggade -->
                    <li class="nav-item" id="nav-loans" style="display:none">
                        <a class="nav-link" asp-controller="Loans" asp-action="Index">Mina lån</a>
                    </li>
                    <!-- Endast för admin -->
                    <li class="nav-item" id="nav-admin-loans" style="display:none">
                        <a class="nav-link" asp-controller="Admin" asp-action="Loans">Admin lån</a>
                    </li>
                    <li class="nav-item" id="nav-admin-users" style="display:none">
                        <a class="nav-link" href="https://user-api-adde.azurewebsites.net/Admin/Users" target="_blank">Hantera användare</a>
                    </li>
                </ul>
            </div>

            <!-- Höger sida i navbar -->
            <ul class="navbar-nav gap-2 align-items-center">
                <!-- Ej inloggad -->
                <li class="nav-item" id="nav-login-btn">
                    <a class="btn-login" href="https://user-api-adde.azurewebsites.net/Authorization/Login">Logga in</a>
                </li>
                <!-- Inloggad -->
                <li class="nav-item" id="nav-profile-btn" style="display:none">
                    <a class="btn-login" href="https://user-api-adde.azurewebsites.net/User/Profile">
                        👤 <span id="nav-username">Profil</span>
                    </a>
                </li>
                <li class="nav-item" id="nav-logout-btn" style="display:none">
                    <a class="btn-logout" onclick="logout()" style="cursor:pointer">Logga ut</a>
                </li>
            </ul>
        </div>
    </nav>
</header>

<main role="main">
    @RenderBody()
</main>

<footer>
    <div class="container">
        &copy; 2026 HV Bibliotek - Grupp T4. All rights reserved.
    </div>
</footer>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>

@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
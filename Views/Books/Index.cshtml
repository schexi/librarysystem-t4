@{
    ViewData["Title"] = "Böcker";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1 class="page-title">📖 Böcker</h1>

<div class="glass-card" style="max-width:900px">
    <div style="display:flex;gap:12px;margin-bottom:20px">
        <input class="search-input" id="bookSearch" placeholder="🔍 Sök titel, författare eller ISBN..."
               oninput="filterBooks()" style="width:100%;font-size:1rem;padding:10px 16px"/>
    </div>

    <div class="tabs">
        <button class="tab-btn active" onclick="filterByCategory('all')">Alla</button>
        <button class="tab-btn" onclick="filterByCategory('fiction')">Skönlitteratur</button>
        <button class="tab-btn" onclick="filterByCategory('nonfiction')">Facklitteratur</button>
        <button class="tab-btn" onclick="filterByCategory('science')">Vetenskap</button>
    </div>

    <div id="bookGrid" class="book-grid"></div>
    <p id="noResults" style="display:none;text-align:center;opacity:.7;padding:30px">
        Inga böcker hittades 📭
    </p>
</div>

@section Scripts {
<script>
const allBooks = [
    { title: "Millennium: Män som hatar kvinnor", author: "Stieg Larsson", isbn: "978-91-7263-498-4", category: "fiction",    available: true  },
    { title: "Sapiens",                           author: "Yuval Noah Harari", isbn: "978-91-89062-00-5", category: "nonfiction", available: false },
    { title: "Röda rummet",                       author: "August Strindberg", isbn: "978-91-7324-123-0", category: "fiction",    available: true  },
    { title: "En kort historik över nästan allt", author: "Bill Bryson",       isbn: "978-91-7263-499-1", category: "science",    available: true  },
    { title: "Brott och straff",                  author: "Fjodor Dostojevskij", isbn: "978-91-7324-124-7", category: "fiction",  available: true  },
    { title: "Kortfattad historik om tiden",      author: "Stephen Hawking",   isbn: "978-91-7263-500-4", category: "science",    available: false },
    { title: "Harry Potter och de vises sten",    author: "J.K. Rowling",      isbn: "978-91-7263-501-1", category: "fiction",    available: true  },
    { title: "Tänka snabbt och långsamt",         author: "Daniel Kahneman",   isbn: "978-91-7324-125-4", category: "nonfiction", available: true  },
];

let currentCategory = 'all';
let currentSearch   = '';

function renderBooks() {
    const filtered = allBooks.filter(b => {
        const matchCat    = currentCategory === 'all' || b.category === currentCategory;
        const matchSearch = b.title.toLowerCase().includes(currentSearch)  ||
                            b.author.toLowerCase().includes(currentSearch) ||
                            b.isbn.includes(currentSearch);
        return matchCat && matchSearch;
    });

    const grid = document.getElementById('bookGrid');
    const none = document.getElementById('noResults');

    if (filtered.length === 0) {
        grid.innerHTML = '';
        none.style.display = 'block';
        return;
    }

    none.style.display = 'none';
    grid.innerHTML = filtered.map((b, i) => `
        <div class="book-card" style="animation-delay:${i * 0.05}s">
            <div style="font-size:2rem;margin-bottom:8px">${categoryEmoji(b.category)}</div>
            <h3>${b.title}</h3>
            <p>${b.author}</p>
            <p style="margin-top:6px;font-size:.75rem;opacity:.5">${b.isbn}</p>
            <div style="margin-top:12px">
                <span style="
                    padding: 4px 10px;
                    border-radius: 20px;
                    font-size: .75rem;
                    font-weight: 600;
                    background: ${b.available ? 'rgba(50,200,100,.3)' : 'rgba(220,50,50,.3)'};
                    color: ${b.available ? '#7fffc4' : '#ff9999'};
                ">
                    ${b.available ? '✓ Tillgänglig' : '✗ Utlånad'}
                </span>
            </div>
        </div>
    `).join('');
}

function filterBooks() {
    currentSearch = document.getElementById('bookSearch').value.toLowerCase();
    renderBooks();
}

function filterByCategory(cat) {
    currentCategory = cat;
    document.querySelectorAll('.tab-btn').forEach(btn => btn.classList.remove('active'));
    event.target.classList.add('active');
    renderBooks();
}

function categoryEmoji(cat) {
    const map = { fiction: '📚', nonfiction: '📰', science: '🔬' };
    return map[cat] || '📖';
}

renderBooks();
</script>
}

@model List<LibrarySystem_T4.Models.CategoryViewModel>

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 style="color: white; font-weight: 700;">Kategorier</h2>
        <a asp-action="Create" style="background: rgba(255,255,255,0.15); border: 1px solid rgba(255,255,255,0.3); color: white; padding: 8px 20px; border-radius: 20px; text-decoration: none; font-weight: 600;">+ Ny kategori</a>
    </div>

    <div class="row g-4">
        @foreach (var c in Model)
        {
            <div class="col-md-4">
                <div style="background: rgba(255,255,255,0.12); backdrop-filter: blur(10px); border: 1px solid rgba(255,255,255,0.25); border-radius: 16px; padding: 24px;">
                    <h5 style="color: white; font-weight: 700; margin-bottom: 4px;">@c.Name</h5>
                    <p style="color: rgba(255,255,255,0.7); font-size: 0.9rem;">@c.Description</p>
                    <div class="d-flex justify-content-between align-items-center mt-3">
                        <div class="d-flex gap-2">
                            <a asp-action="Edit" asp-route-id="@c.Id" style="background: rgba(0,0,0,0.3); color: white; padding: 6px 16px; border-radius: 8px; text-decoration: none; font-size: 0.85rem;">Redigera</a>
                            <a asp-action="Delete" asp-route-id="@c.Id" style="background: rgba(0,0,0,0.3); color: white; padding: 6px 16px; border-radius: 8px; text-decoration: none; font-size: 0.85rem;">Ta bort</a>
                        </div>
                       
                    </div>
                </div>
            </div>
        }
    </div>
</div>
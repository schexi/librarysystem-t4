@model LibrarySystem_T4.Models.CategoryViewModel

          @*Modell för att skapa ny kategori*@
<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 style="color:white; font-weight:700;">Kategorier</h2>
        <a asp-action="Create" class="btn" style="background:rgba(255,255,255,0.2); color:white; border:1px solid rgba(255,255,255,0.3); border-radius:20px;">+ Ny kategori</a>
    </div>

    <div class="row">
        @foreach (var category in Model)
        {
            <div class="col-md-4 mb-4">
                <div style="background:rgba(255,255,255,0.15); border:1px solid rgba(255,255,255,0.25); border-radius:16px; padding:1.5rem; backdrop-filter:blur(8px);">
                    <h5 style="color:white; font-weight:600;">@category.Name</h5>
                    <p style="color:rgba(255,255,255,0.75); font-size:.9rem;">@category.Description</p>
                    <div class="d-flex gap-2 mt-3">
                        <a asp-action="Edit" asp-route-id="@category.Id" class="btn btn-sm" style="background:rgba(255,255,255,0.2); color:white; border:1px solid rgba(255,255,255,0.3);">Redigera</a>
                        <form asp-action="Delete" asp-route-id="@category.Id" method="post">
                            <button type="submit" class="btn btn-sm" style="background:rgba(220,50,50,0.3); color:white; border:1px solid rgba(220,50,50,0.4);">Ta bort</button>
                        </form>
                        <span class="btn btn-sm ms-auto" style="background:rgba(50,200,100,0.25); color:#7fffb2; border:1px solid rgba(50,200,100,0.3);">Tillgänglig</span>
                    </div>
                </div>
            </div>
        }
    </div>
    
    
               @*Modell för att redigera en kategori*@
    <div class="container mt-4" style="max-width:500px;">
        <div style="background:rgba(255,255,255,0.15); border:1px solid rgba(255,255,255,0.25); border-radius:16px; padding:2rem; backdrop-filter:blur(8px);">
            <h2 style="color:white; font-weight:700; margin-bottom:1.5rem;">Redigera kategori</h2>

            <form asp-action="Edit" asp-route-id="@Model.Id" method="post">
                <input asp-for="Id" type="hidden"/>
                <div class="mb-3">
                    <label asp-for="Name" style="color:rgba(255,255,255,0.75); font-size:.85rem;">Namn</label>
                    <input asp-for="Name" class="form-control mt-1"
                           style="background:rgba(255,255,255,0.15); border:1px solid rgba(255,255,255,0.25); color:white; border-radius:8px;"/>
                </div>
                <div class="mb-3">
                    <label asp-for="Description" style="color:rgba(255,255,255,0.75); font-size:.85rem;">Beskrivning</label>
                    <textarea asp-for="Description" class="form-control mt-1" rows="3"
                          style="background:rgba(255,255,255,0.15); border:1px solid rgba(255,255,255,0.25); color:white; border-radius:8px;"></textarea>
                </div>
                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn" style="background:rgba(255,255,255,0.2); color:white; border:1px solid rgba(255,255,255,0.3); border-radius:8px;">Spara</button>
                    <a asp-action="Index" class="btn" style="background:rgba(255,255,255,0.1); color:white; border:1px solid rgba(255,255,255,0.2); border-radius:8px;">Avbryt</a>
                </div>
            </form>
        </div>
    </div>
    
</div>
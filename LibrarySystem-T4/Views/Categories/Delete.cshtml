@model LibrarySystem_T4.Models.CategoryViewModel

<div class="container py-4" style="max-width: 500px;">
    <h2 style="color: white; font-weight: 700; margin-bottom: 24px;">Ta bort kategori</h2>

    <div style="background: rgba(255,255,255,0.12); backdrop-filter: blur(10px); border: 1px solid rgba(255,255,255,0.25); border-radius: 16px; padding: 32px;">
        <p style="color: rgba(255,255,255,0.85); font-size: 1.05rem; margin-bottom: 8px;">Är du säker på att du vill ta bort:</p>
        <h4 style="color: white; font-weight: 700;">@Model.Name</h4>
        <p style="color: rgba(255,255,255,0.6); margin-bottom: 24px;">@Model.Description</p>

        <form asp-action="Delete" method="post">
            <input type="hidden" name="id" value="@Model.Id" />
            <div class="d-flex gap-2">
                <button type="submit" style="background: #e63946; color: white; border: none; padding: 10px 24px; border-radius: 10px; font-weight: 700; cursor: pointer;">Ja, ta bort</button>
                <a asp-action="Index" style="background: rgba(255,255,255,0.15); border: 1px solid rgba(255,255,255,0.3); color: white; padding: 10px 24px; border-radius: 10px; text-decoration: none; font-weight: 600;">Avbryt</a>
            </div>
        </form>
    </div>
</div>
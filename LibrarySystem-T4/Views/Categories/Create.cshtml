@model LibrarySystem_T4.Models.Category

<div class="container mt-4">
    <h2>Ny kategori</h2>

    <form asp-action="Create" method="post">
        <div class="mb-3">
            <label asp-for="Name" class="form-label">Namn</label>
            <input asp-for="Name" class="form-control" placeholder="t.ex. Böcker" />
        </div>
        <div class="mb-3">
            <label asp-for="Description" class="form-label">Beskrivning</label>
            <textarea asp-for="Description" class="form-control" rows="3" placeholder="Beskriv kategorin..."></textarea>
        </div>
        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">Spara</button>
            <a asp-action="Index" class="btn btn-secondary">Avbryt</a>
        </div>
    </form>
</div>

@model LibrarySystem_T4.Models.CategoryViewModel

<div class="container py-4" style="max-width: 500px;">
    <h2 style="color: white; font-weight: 700; margin-bottom: 24px;">Lägg till kategori</h2>

    <div style="background: rgba(255,255,255,0.12); backdrop-filter: blur(10px); border: 1px solid rgba(255,255,255,0.25); border-radius: 16px; padding: 32px;">
        <form asp-action="Create" method="post">
            <div class="mb-3">
                <label style="color: rgba(255,255,255,0.8); font-weight: 600; margin-bottom: 6px; display: block;">Namn</label>
                <input asp-for="Name" style="width: 100%; padding: 10px 14px; border-radius: 10px; border: 1px solid rgba(255,255,255,0.25); background: rgba(255,255,255,0.1); color: white; font-size: 1rem;" />
            </div>
            <div class="mb-4">
                <label style="color: rgba(255,255,255,0.8); font-weight: 600; margin-bottom: 6px; display: block;">Beskrivning</label>
                <input asp-for="Description" style="width: 100%; padding: 10px 14px; border-radius: 10px; border: 1px solid rgba(255,255,255,0.25); background: rgba(255,255,255,0.1); color: white; font-size: 1rem;" />
            </div>
            <div class="d-flex gap-2">
                <button type="submit" style="background: #06d6a0; color: #0d3b6e; border: none; padding: 10px 24px; border-radius: 10px; font-weight: 700; cursor: pointer;">Spara</button>
                <a asp-action="Index" style="background: rgba(255,255,255,0.15); border: 1px solid rgba(255,255,255,0.3); color: white; padding: 10px 24px; border-radius: 10px; text-decoration: none; font-weight: 600;">Tillbaka</a>
            </div>
        </form>
    </div>
</div>
@{
ViewData["Title"] = "Admin — Alla lån";
Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1 class="page-title">📚 Alla lån</h1>

<div class="glass-card" style="max-width:1100px">
    <div class="stats-grid" style="margin-bottom:24px">
        <div class="stat-box">
            <label>📖 Totalt aktiva lån</label>
            <div id="activeCount" class="stat-value">–</div>
        </div>
        <div class="stat-box">
            <label>✅ Returnerade</label>
            <div id="returnedCount" class="stat-value">–</div>
        </div>
        <div class="stat-box">
            <label>⚠️ Försenade</label>
            <div id="overdueCount" class="stat-value">–</div>
        </div>
    </div>

    <div class="tabs" style="margin-bottom:20px">
        <button class="tab-btn active" onclick="showTab('active')">Aktiva lån</button>
        <button class="tab-btn" onclick="showTab('returned')">Returnerade</button>
        <button class="tab-btn" onclick="showTab('overdue')">⚠️ Försenade</button>
    </div>

    <div id="activeTab"><p style="opacity:.7;padding:20px">Laddar...</p></div>
    <div id="returnedTab" style="display:none"><p style="opacity:.7;padding:20px">Laddar...</p></div>
    <div id="overdueTab" style="display:none"><p style="opacity:.7;padding:20px">Laddar...</p></div>
</div>

@section Scripts {
<script>
    const _token = localStorage.getItem('jwt_token');
    const _user  = JSON.parse(localStorage.getItem('user_info') || 'null');
    if (!_token || !_user || _user.role !== 'Admin') {
        window.location.href = '/Authorization/Login';
    }

    let allLoans = [];

    (async () => {
        const res = await apiFetch('/api/loans/all');
        if (!res.ok) { document.getElementById('activeTab').innerHTML = '<p style="opacity:.7;padding:20px">Kunde inte hämta lån.</p>'; return; }
        allLoans = await res.json();

        const active   = allLoans.filter(l => !l.isReturned);
        const returned = allLoans.filter(l => l.isReturned);
        const overdue  = allLoans.filter(l => !l.isReturned && new Date(l.dueDate) < new Date());

        document.getElementById('activeCount').textContent   = active.length;
        document.getElementById('returnedCount').textContent = returned.length;
        document.getElementById('overdueCount').textContent  = overdue.length;

        renderTab('active');
    })();

    function renderTab(tab) {
        const active   = allLoans.filter(l => !l.isReturned);
        const returned = allLoans.filter(l => l.isReturned);
        const overdue  = allLoans.filter(l => !l.isReturned && new Date(l.dueDate) < new Date());

        const lists = { active, returned, overdue };
        const loans = lists[tab];

        const html = loans.length === 0
            ? '<p style="opacity:.7;text-align:center;padding:20px">Inga lån.</p>'
            : loans.map(l => {
                const isLate = !l.isReturned && new Date(l.dueDate) < new Date();
                return `
            <div class="loan-item">
                <div style="flex:1">
                    <div class="loan-title">${l.bookTitle}</div>
                    <div class="loan-author">${l.bookAuthor || ''}</div>
                    <div style="font-size:.8rem;opacity:.6;margin-top:4px">
                        Användare: <strong>${l.user?.username || l.userId}</strong> •
                        Lånad: ${fmt(l.borrowedDate)} •
                        Förfaller: <span style="color:${isLate ? '#ff6b6b' : '#6ee7b7'}">${fmt(l.dueDate)}</span>
                        ${l.isReturned ? ' • Returnerad: ' + fmt(l.returnedDate) : ''}
                    </div>
                </div>
                <div style="display:flex;flex-direction:column;align-items:flex-end;gap:8px">
                    <span class="loan-badge ${l.isReturned ? 'returned' : 'active'}">
                        ${isLate ? '⚠️ Försenad' : l.isReturned ? '✅ Returnerad' : '📖 Aktiv'}
                    </span>
                    ${!l.isReturned ? `
                    <button onclick="adminReturn(${l.id})"
                        style="background:#06d6a0;border:none;color:#04342c;padding:6px 14px;border-radius:8px;font-weight:700;cursor:pointer;font-size:.82rem">
                        Återlämna
                    </button>` : ''}
                    <button onclick="adminDelete(${l.id})"
                        style="background:rgba(220,53,69,0.15);border:1px solid rgba(220,53,69,0.4);color:#ff8896;padding:6px 14px;border-radius:8px;font-weight:700;cursor:pointer;font-size:.82rem">
                        Radera
                    </button>
                </div>
            </div>`;
            }).join('');

        document.getElementById(`${tab}Tab`).innerHTML = html;
    }

    function showTab(tab) {
        ['active','returned','overdue'].forEach(t => {
            document.getElementById(`${t}Tab`).style.display = t === tab ? 'block' : 'none';
        });
        document.querySelectorAll('.tab-btn').forEach((b, i) =>
            b.classList.toggle('active', ['active','returned','overdue'][i] === tab));
        renderTab(tab);
    }

    async function adminReturn(id) {
        if (!confirm('Återlämna detta lån?')) return;
        const res = await apiFetch(`/api/loans/${id}/return`, { method: 'POST' });
        if (res.ok) {
            const loan = allLoans.find(l => l.id === id);
            if (loan) { loan.isReturned = true; loan.returnedDate = new Date().toISOString(); }
            renderTab('active');
            updateCounts();
            showToast('✅ Lån återlämnat!');
        }
}

    async function adminDelete(id) {
        if (!confirm('Radera detta lån permanent?')) return;
        const res = await apiFetch(`/api/loans/${id}`, { method: 'DELETE' });
        if (res.ok) {
            allLoans = allLoans.filter(l => l.id !== id);
            renderTab('active');
            updateCounts();
            showToast('🗑 Lån raderat!');
        }
}

    function updateCounts() {
        document.getElementById('activeCount').textContent   = allLoans.filter(l => !l.isReturned).length;
        document.getElementById('returnedCount').textContent = allLoans.filter(l => l.isReturned).length;
        document.getElementById('overdueCount').textContent  = allLoans.filter(l => !l.isReturned && new Date(l.dueDate) < new Date()).length;
    }

    function fmt(d) { return d ? new Date(d).toLocaleDateString('sv-SE') : '–'; }

    function showToast(msg) {
        const t = document.createElement('div');
        t.textContent = msg;
        t.style.cssText = 'position:fixed;bottom:24px;right:24px;background:rgba(50,200,100,.9);color:#fff;padding:12px 24px;border-radius:12px;font-weight:600;z-index:9999;';
        document.body.appendChild(t);
        setTimeout(() => t.remove(), 3000);
    }
</script>
}
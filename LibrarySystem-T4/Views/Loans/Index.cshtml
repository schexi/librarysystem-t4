@model List<LibrarySystem_T4.Models.LoanViewModel>

@{
    ViewData["Title"] = "Alla lån";
}

<style>
    .loans-container {
        max-width: 1100px;
        margin: 40px auto;
        padding: 0 20px;
    }

    h1 {
        color: white;
        font-size: 2rem;
        font-weight: 700;
        margin-bottom: 24px;
    }

    .empty-message {
        background: rgba(255,255,255,0.08);
        border: 1px solid rgba(255,255,255,0.18);
        border-radius: 14px;
        padding: 40px;
        text-align: center;
        color: white;
    }

    .loan-card {
        background: rgba(255,255,255,0.08);
        border: 1px solid rgba(255,255,255,0.18);
        border-radius: 14px;
        padding: 18px 20px;
        margin-bottom: 14px;
        color: white;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 16px;
    }

    .card-left {
        display: flex;
        flex-direction: column;
        gap: 2px;
        min-width: 180px;
    }

    .card-right {
        display: flex;
        align-items: center;
        gap: 24px;
    }

    .btn-area {
        width: 100px;
        display: flex;
        justify-content: flex-end;
    }

    .badge-active {
        background: rgba(255,200,0,0.25);
        color: #ffe566;
        border: 1px solid rgba(255,200,0,0.4);
        padding: 3px 0;
        border-radius: 4px;
        font-size: 11px;
        font-weight: 600;
        display: inline-block;
        margin-bottom: 6px;
        width: 72px;
        text-align: center;
    }

    .badge-done {
        background: rgba(6,214,160,0.25);
        color: #06d6a0;
        border: 1px solid rgba(6,214,160,0.4);
        padding: 3px 0;
        border-radius: 4px;
        font-size: 11px;
        font-weight: 600;
        display: inline-block;
        margin-bottom: 6px;
        width: 72px;
        text-align: center;
    }

    .loan-id {
        font-size: 11px;
        opacity: 0.7;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .loan-name {
        font-size: 15px;
        font-weight: 600;
    }

    .loan-email {
        font-size: 12px;
        opacity: 0.8;
    }

    .dates {
        display: flex;
        gap: 20px;
    }

    .date-block {
        display: flex;
        flex-direction: column;
        align-items: flex-end;
    }

    .date-label {
        font-size: 10px;
        opacity: 0.7;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .date-val {
        font-size: 13px;
        font-weight: 500;
    }

    .btn-return {
        background: #06d6a0;
        border: none;
        color: #04342c;
        padding: 8px 18px;
        border-radius: 8px;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
    }

    .btn-delete {
        background: rgba(255,100,100,0.25);
        border: 1px solid rgba(255,100,100,0.4);
        color: #ff6b6b;
        padding: 8px 18px;
        border-radius: 8px;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
    }

    .btn-create {
        display: inline-block;
        margin-top: 24px;
        background: white;
        color: #0f4c75;
        padding: 12px 28px;
        border-radius: 10px;
        font-weight: 700;
        font-size: 0.95rem;
        text-decoration: none;
    }
</style>

<div class="loans-container">
    <h1>Alla lån</h1>

    @if (!Model.Any())
    {
        <div class="empty-message">Inga lån registrerade.</div>
    }
    else
    {
        @foreach (var loan in Model)
        {
            <div class="loan-card">
                <div class="card-left">
                    @if (!loan.ReturnedDate.HasValue)
                    {
                        <span class="badge-active">Aktiv</span>
                    }
                    else
                    {
                        <span class="badge-done">Återlämnad</span>
                    }
                    <span class="loan-id">Lån #@loan.LoanId · Objekt #@loan.ItemId</span>
                    <span class="loan-name">@loan.BorrowerName</span>
                    <span class="loan-email">@loan.BorrowerEmail</span>
                </div>

                <div class="card-right">
                    <div class="dates">
                        <div class="date-block">
                            <span class="date-label">Utlånad</span>
                            <span class="date-val">@loan.BorrowedDate.ToShortDateString()</span>
                        </div>
                        <div class="date-block">
                            <span class="date-label">Förfaller</span>
                            <span class="date-val">@loan.DueDate.ToShortDateString()</span>
                        </div>
                        <div class="date-block">
                            <span class="date-label">Återlämnad</span>
                            <span class="date-val">
                                @(loan.ReturnedDate.HasValue
                                    ? loan.ReturnedDate.Value.ToShortDateString()
                                    : "–")
                            </span>
                        </div>
                    </div>
                    <div class="btn-area" style="width: auto; gap: 8px;">
                        @if (!loan.ReturnedDate.HasValue)
                        {
                            <form method="post" asp-action="Return" asp-route-id="@loan.LoanId" style="display:inline;">
                                <button type="submit" class="btn-return">Återlämna</button>
                            </form>
                        }
                        <form method="post" asp-action="Delete" asp-route-id="@loan.LoanId" style="display:inline;">
                            <button type="submit" class="btn-delete">Radera</button>
                        </form>
                    </div>
                </div>
            </div>
        }
    }

    <a asp-action="Create" class="btn-create">+ Skapa nytt lån</a>
</div>
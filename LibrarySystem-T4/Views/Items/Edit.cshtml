@model LibrarySystem_T4.Controllers.ItemViewModel

@{
    ViewData["Title"] = "Redigera objekt";
}

<link rel="stylesheet" href="~/css/items.css" asp-append-version="true"/>

<div class="items-page">
    <div class="page-header">
        <h2>Redigera objekt</h2>
        <a asp-action="Index" class="btn-back">← Tillbaka</a>
    </div>

    <form asp-action="Edit" method="post" class="item-form">
        <input asp-for="Id" type="hidden"/>
        <div class="form-group">
            <label>Titel</label>
            <input asp-for="Title" class="form-input"/>
        </div>
        <div class="form-group">
            <label>Beskrivning</label>
            <input asp-for="Description" class="form-input"/>
        </div>
        <div class="form-group">
            <label>Kategori</label>
            <input asp-for="Category" class="form-input"/>
        </div>
        <div class="form-group">
            <label>Tillgänglig</label>
            <input asp-for="IsAvailable" type="checkbox" class="form-checkbox"/>
        </div>
        <button type="submit" class="btn-create">Spara</button>
    </form>
</div>
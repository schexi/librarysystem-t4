@model LibrarySystem_T4.Models.ItemViewModel

@{
    ViewData["Title"] = "Redigera bok";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div style="max-width:600px;margin:40px auto;padding:0 20px">
    <h1 style="color:white;font-size:2rem;font-weight:700;margin-bottom:24px">✏️ Redigera bok</h1>
    <div style="background:rgba(255,255,255,0.10);border:1px solid rgba(255,255,255,0.18);border-radius:14px;padding:32px">
        <form asp-action="Edit" method="post">
            <input asp-for="Id" type="hidden"/>
            <input asp-for="IsAvailable" type="hidden"/>

            <div style="margin-bottom:16px">
                <label style="color:rgba(255,255,255,0.8);font-size:.85rem;font-weight:600;text-transform:uppercase;display:block;margin-bottom:6px">Titel</label>
                <input asp-for="Title" style="background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.2);color:white;border-radius:8px;padding:10px 14px;width:100%"/>
            </div>

            <div style="margin-bottom:16px">
                <label style="color:rgba(255,255,255,0.8);font-size:.85rem;font-weight:600;text-transform:uppercase;display:block;margin-bottom:6px">Beskrivning</label>
                <input asp-for="Description" style="background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.2);color:white;border-radius:8px;padding:10px 14px;width:100%"/>
            </div>

            <div style="margin-bottom:24px">
                <label style="color:rgba(255,255,255,0.8);font-size:.85rem;font-weight:600;text-transform:uppercase;display:block;margin-bottom:6px">Kategori</label>
                <select asp-for="Category" style="background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.2);color:white;border-radius:8px;padding:10px 14px;width:100%">
                    <option value="">Välj kategori</option>
                    @foreach (var cat in ViewBag.Categories)
                    {
                        <option value="@cat.Name" selected="@(cat.Name == Model.Category)">@cat.Name</option>
                    }
                </select>
            </div>

            <div style="display:flex;gap:12px">
                <button type="submit" style="background:#06d6a0;border:none;color:#04342c;padding:12px 28px;border-radius:10px;font-weight:700;cursor:pointer;font-size:1rem">
                    💾 Spara
                </button>
                <a asp-action="Index" style="background:rgba(255,255,255,0.15);border:1px solid rgba(255,255,255,0.3);color:white;padding:12px 28px;border-radius:10px;font-weight:700;text-decoration:none;font-size:1rem">
                    ← Tillbaka
                </a>
            </div>
        </form>
    </div>
</div>
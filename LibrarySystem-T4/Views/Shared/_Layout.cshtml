<!DOCTYPE html>
<html lang="sv">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] - HV Bibliotek</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            background: linear-gradient(135deg, #0d3b6e 0%, #1b9aaa 50%, #06d6a0 100%);
            min-height: 100vh;
            font-family: 'Segoe UI', sans-serif;
            display: flex;
            flex-direction: column;
        }

        nav {
            background: rgba(255,255,255,0.15) !important;
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255,255,255,0.25) !important;
            border-radius: 16px;
            margin: 16px;
            padding: 10px 24px !important;
        }

        .navbar-brand {
            color: white !important;
            font-weight: 700;
            font-size: 1.3rem;
        }

        .nav-link {
            color: white !important;
            font-weight: 600;
            padding: 10px 20px !important;
            border-radius: 8px;
            font-size: 1.2rem !important;
            border: 1px solid rgba(255,255,255,0.3);
            transition: background 0.2s;
        }

        .nav-link:hover {
            background: rgba(255,255,255,0.2);
            color: white !important;
        }

        .navbar-toggler {
            border-color: rgba(255,255,255,0.5);
        }

        .navbar-toggler-icon {
            filter: invert(1);
        }

        .nav-logged-in {
            color: white !important;
            opacity: 0.85;
            font-size: 0.9rem;
            align-self: center;
        }

        main {
            flex: 1;
            padding: 0 16px;
        }

        footer {
            background: rgba(0,0,0,0.2);
            color: rgba(255,255,255,0.7);
            text-align: center;
            padding: 16px;
            font-size: 0.85rem;
            border-top: 1px solid rgba(255,255,255,0.1);
        }

        footer a {
            color: rgba(255,255,255,0.7);
        }
    </style>
</head>
<body>
<header>
    <nav class="navbar navbar-expand-sm">
        <div class="container-fluid">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">HV Bibliotek</a>
            <div class="navbar-collapse collapse d-sm-inline-flex justify-content-center flex-grow-1">
                <ul class="navbar-nav">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Loans" asp-action="Index">Mina lån</a>
                    </li>
                </ul>
            </div>
            <span class="nav-logged-in">Inloggad som: XXXX</span>
        </div>
    </nav>
</header>

<main role="main">
    @RenderBody()
</main>

<footer>
    <div class="container">
        &copy; 2026 HV Bibliotek - Grupp T4. All rights reserved.
    </div>
</footer>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>